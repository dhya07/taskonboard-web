# =============================================================================
# TaskOnBoard Admin — TEMPLATE ONLY (safe to commit). Do NOT put real keys here.
# =============================================================================
#
# Copy values into gitignored files (never commit these):
#   .env.development  →  npm run dev
#   .env.production   →  npm run build / Vercel env vars
#
# Vite: https://vitejs.dev/guide/env-and-mode.html
#
# Backend Firebase projects (server only; not pasted into this file):
#   Dev  → backend/serviceAccountKey-dev.json  → taskonboard-dev
#   Prod → backend/serviceAccountKey.json      → taskonboard
#
# =============================================================================
# .env.development — example shape (fill from Firebase Console → Web app)
# =============================================================================
#
# VITE_API_URL=https://taskonboard-backend.onrender.com/api
# VITE_ENV_NAME=Development
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=taskonboard-dev
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
#
# =============================================================================
# .env.production — example shape
# =============================================================================
#
# VITE_API_URL=https://taskonboard.onrender.com/api
# VITE_ENV_NAME=Production
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=taskonboard
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
#
# =============================================================================
# Blank template (optional single scratch file — prefer .env.development)
# =============================================================================

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_API_URL=https://taskonboard-backend.onrender.com/api
